# Pushover – notifiering vid driftstörningar (databas, frontend, backend)
# User Key: https://pushover.net/ (din dashboard)
PUSHOVER_USER_KEY=
# Antingen Application API Token (30 tecken från https://pushover.net/apps)
# eller e-postalias för Pushovers e-postgateway (t.ex. mittalias → mittalias@pwp.route.pushover.net)
PUSHOVER_EMAIL_ALIAS=
APP_NAME=Kyrkevent Bokning

# Övervakning i backend-processen (databas + frontend)
SERVICE_MONITOR_ENABLED=true
SERVICE_MONITOR_INTERVAL_MINUTES=15
DB_MONITOR_INTERVAL_MINUTES=15
FRONTEND_MONITOR_INTERVAL_MINUTES=15
DB_MONITOR_ENABLED=true
FRONTEND_MONITOR_ENABLED=true
# FRONTEND_MONITOR_URL=https://www.kyrkevent.se
# FRONTEND_URL används om FRONTEND_MONITOR_URL saknas
# Lokalt (Vite https): FRONTEND_MONITOR_ALLOW_INSECURE_SSL=true eller NODE_ENV!=production
# SERVICE_MONITOR_VERBOSE=true  # logga varje kontroll i konsolen

# Separat övervakare för backend (krävs för "backend nere" – se npm run monitor)
# Sätt BACKEND_HEALTH_URL till din publika API-URL, t.ex. https://xxx.railway.app/health
BACKEND_HEALTH_URL=
BACKEND_MONITOR_ENABLED=true
UPTIME_MONITOR_INTERVAL_MINUTES=5
# UPTIME_MONITOR_FRONTEND=true  # valfritt om du vill att standalone även kollar frontend
# Kör: npm run monitor (egen Railway-tjänst eller Cron Job)
