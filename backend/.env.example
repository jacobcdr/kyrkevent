# Pushover – notifiering vid databasfel
# User Key: https://pushover.net/ (din dashboard)
PUSHOVER_USER_KEY=
# Antingen Application API Token (30 tecken från https://pushover.net/apps)
# eller e-postalias för Pushovers e-postgateway (t.ex. mittalias → mittalias@pwp.route.pushover.net)
PUSHOVER_EMAIL_ALIAS=
DB_MONITOR_INTERVAL_MINUTES=15
DB_MONITOR_ENABLED=true
